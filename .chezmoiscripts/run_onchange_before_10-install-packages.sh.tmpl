#!/usr/bin/env bash
set -euo pipefail

log() {
    printf '[dotfiles] %s\n' "$*"
}

{{ if eq .chezmoi.os "darwin" -}}
if ! command -v brew >/dev/null 2>&1; then
    log "Installing Homebrew"
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
else
    eval "$(/usr/local/bin/brew shellenv)"
fi

declare -A formula_commands=(
    [clang-format]=clang-format
    [cmake]=cmake
    [fzf]=fzf
    [git]=git
    [jq]=jq
    [mise]=mise
    [ninja]=ninja
    [opencode]=opencode
    [ripgrep]=rg
    [shellcheck]=shellcheck
    [tmux]=tmux
    [wget]=wget
    [zsh]=zsh
)
for formula in "${!formula_commands[@]}"; do
    command="${formula_commands[$formula]}"
    if ! command -v "$command" >/dev/null 2>&1; then
        log "Installing missing command '$command'"
        brew install "$formula"
    fi
done

{{ if eq .role "desktop" -}}
declare -A cask_apps=(
    [1password]="1Password.app"
    [displaylink]="DisplayLink Manager.app"
    [ghostty]="Ghostty.app"
    [google-chrome]="Google Chrome.app"
    [obs]="OBS.app"
    [raycast]="Raycast.app"
    [rode-central]="RODE Central.app"
    [rode-virtual-channels]="RODE Virtual Channels.app"
    [spotify]="Spotify.app"
{{ if eq .profile "work" -}}
    [slack]="Slack.app"
{{ end -}}
)
for cask in "${!cask_apps[@]}"; do
    app="${cask_apps[$cask]}"
    if [[ ! -d "/Applications/$app" && ! -d "$HOME/Applications/$app" ]]; then
        log "Installing missing app '$app'"
        brew install --cask "$cask" || log "Skipping optional cask '$cask'"
    fi
done

if ! command -v op >/dev/null 2>&1; then
    brew install --cask 1password-cli
fi

if [[ ! -d "/Applications/AeroSpace.app" && ! -d "$HOME/Applications/AeroSpace.app" ]]; then
    if ! brew tap | grep -qx 'nikitabobko/tap'; then
        brew tap nikitabobko/tap
    fi
    brew trust --cask nikitabobko/tap/aerospace 2>/dev/null || true
    brew install --cask nikitabobko/tap/aerospace || log "Skipping optional cask 'aerospace'"
fi
{{ end -}}
{{ else if eq .chezmoi.os "linux" -}}
sudo_cmd=()
if (( EUID != 0 )); then
    if ! command -v sudo >/dev/null 2>&1; then
        printf '[dotfiles] ERROR: sudo is required for package installation\n' >&2
        exit 1
    fi
    sudo_cmd=(sudo)
fi

packages=()
add_package() {
    command -v "$1" >/dev/null 2>&1 || packages+=("$2")
}

case {{ .distro | quote }} in
    ubuntu|debian)
        add_package cc build-essential
        add_package clang-format clang-format
        add_package cmake cmake
        add_package curl curl
        add_package fzf fzf
        add_package git git
        add_package gpg gnupg
        add_package jq jq
        add_package make build-essential
        add_package ninja ninja-build
        add_package rg ripgrep
        add_package shellcheck shellcheck
        add_package tmux tmux
        add_package unzip unzip
        add_package wget wget
        add_package zsh zsh
        if (( ${#packages[@]} )); then
            "${sudo_cmd[@]}" apt-get update
            "${sudo_cmd[@]}" env DEBIAN_FRONTEND=noninteractive apt-get install -y "${packages[@]}"
        fi
        ;;
    fedora)
        add_package cc gcc
        add_package clang-format clang-tools-extra
        add_package cmake cmake
        add_package curl curl
        add_package fzf fzf
        add_package git git
        add_package jq jq
        add_package make make
        add_package ninja ninja-build
        add_package rg ripgrep
        add_package shellcheck ShellCheck
        add_package tmux tmux
        add_package unzip unzip
        add_package wget wget
        add_package zsh zsh
        (( ! ${#packages[@]} )) || "${sudo_cmd[@]}" dnf install -y "${packages[@]}"
        ;;
    *)
        printf '[dotfiles] ERROR: Unsupported Linux distribution: %s\n' {{ .distro | quote }} >&2
        exit 1
        ;;
esac

if ! command -v mise >/dev/null 2>&1; then
    log "Installing mise"
    curl -fsSL https://mise.run | sh
fi

if ! command -v opencode >/dev/null 2>&1; then
    log "Installing OpenCode"
    curl -fsSL https://opencode.ai/install | bash
fi

{{ if and (eq .profile "work") .useOnePassword -}}
if ! command -v op >/dev/null 2>&1; then
    log "Installing 1Password CLI"
    case {{ .distro | quote }} in
        ubuntu|debian)
            curl -fsSL https://downloads.1password.com/linux/keys/1password.asc \
                | gpg --dearmor \
                | "${sudo_cmd[@]}" tee /usr/share/keyrings/1password-archive-keyring.gpg >/dev/null
            printf 'deb [arch=%s signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/%s stable main\n' \
                "$(dpkg --print-architecture)" "$(dpkg --print-architecture)" \
                | "${sudo_cmd[@]}" tee /etc/apt/sources.list.d/1password.list >/dev/null
            "${sudo_cmd[@]}" apt-get update
            "${sudo_cmd[@]}" apt-get install -y 1password-cli
            ;;
        fedora)
            "${sudo_cmd[@]}" rpm --import https://downloads.1password.com/linux/keys/1password.asc
            "${sudo_cmd[@]}" sh -c 'printf "%s\n" \
                "[1password]" \
                "name=1Password Stable Channel" \
                "baseurl=https://downloads.1password.com/linux/rpm/stable/\$basearch" \
                "enabled=1" \
                "gpgcheck=1" \
                "repo_gpgcheck=1" \
                "gpgkey=https://downloads.1password.com/linux/keys/1password.asc" \
                > /etc/yum.repos.d/1password.repo'
            "${sudo_cmd[@]}" dnf install -y 1password-cli
            ;;
    esac
fi
{{ end -}}
{{ end -}}

mise_bin="$(command -v mise || true)"
[[ -n "$mise_bin" ]] || mise_bin="$HOME/.local/bin/mise"
if [[ -x "$mise_bin" ]]; then
    install_mise_tool() {
        command -v "$1" >/dev/null 2>&1 || "$mise_bin" use --global "$2"
    }
    install_mise_tool atuin atuin@latest
    install_mise_tool delta delta@latest
    install_mise_tool go go@latest
    install_mise_tool nvim neovim@latest
    install_mise_tool node node@lts
    install_mise_tool python3 python@3.11
    install_mise_tool cargo rust@stable
    install_mise_tool zoxide zoxide@latest
fi
