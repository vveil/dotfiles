#!/bin/sh
set -eu

repo="${DOTFILES_REPO:-https://github.com/vveil/dotfiles.git}"
bin_dir="${HOME}/.local/bin"
chezmoi="${bin_dir}/chezmoi"

mkdir -p "$bin_dir"

if ! command -v chezmoi >/dev/null 2>&1 && [ ! -x "$chezmoi" ]; then
    printf '[dotfiles] Installing chezmoi\n'
    if command -v curl >/dev/null 2>&1; then
        sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$bin_dir"
    elif command -v wget >/dev/null 2>&1; then
        sh -c "$(wget -qO- get.chezmoi.io)" -- -b "$bin_dir"
    else
        printf '[dotfiles] ERROR: curl or wget is required\n' >&2
        exit 1
    fi
fi

if command -v chezmoi >/dev/null 2>&1; then
    chezmoi="$(command -v chezmoi)"
fi

exec "$chezmoi" init --apply "$repo" "$@"
